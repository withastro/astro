{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "prebuild": {
      "dependsOn": ["^prebuild"],
      "inputs": [
        "**/*",
        "!test/**/*",
        "!e2e/**/*",
        "!performance/**/*",
        "!.astro/**/*",
        "!.cache/**/*",
        "!.turbo/**/*",
        "!mod.js",
        "!mod.js.map"
      ],
      "outputs": ["src/**/*.prebuilt*"]
    },
    "build": {
      "dependsOn": ["^build", "prebuild"],
      "inputs": [
        "**/*",
        "!test/**/*",
        "!e2e/**/*",
        "!performance/**/*",
        "!.astro/**/*",
        "!.cache/**/*",
        "!.turbo/**/*",
        "!mod.js",
        "!mod.js.map"
      ],
      "outputs": ["dist/**/*", "!vendor/**", "mod.js", "mod.js.map"],
      "outputLogs": "new-only",
      "passThroughEnv": ["SKIP_OG", "PUBLIC_TWO_LANG"]
    },
    "build:ci": {
      "dependsOn": ["^build:ci", "prebuild"],
      "inputs": [
        "**/*",
        "!test/**/*",
        "!e2e/**/*",
        "!performance/**/*",
        "!.astro/**/*",
        "!.cache/**/*",
        "!.turbo/**/*",
        "!mod.js",
        "!mod.js.map"
      ],
      "outputs": ["dist/**/*", "!vendor/**", "mod.js", "mod.js.map"],
      "outputLogs": "new-only"
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build:fixtures": {
      "dependsOn": ["build"],
      "inputs": [
        "test/fixtures/standard-static/src/**",
        "test/fixtures/standard-static/astro.config.mjs",
        "test/fixtures/standard-static/package.json",
        "test/fixtures/standard-framework-slots/src/**",
        "test/fixtures/standard-framework-slots/astro.config.mjs",
        "test/fixtures/standard-framework-slots/package.json",
        "test/preludes/**",
        "test/preamble.ts"
      ],
      "outputs": [
        "test/fixtures/standard-static/dist/**",
        "test/fixtures/standard-framework-slots/dist/**"
      ],
      "outputLogs": "new-only"
    },
    "test": {
      "dependsOn": ["^test"],
      "env": ["RUNNER_OS", "NODE_VERSION"],
      "outputLogs": "new-only"
    },
    "test:hosted": {
      "cache": false,
      "outputLogs": "new-only"
    }
  }
}

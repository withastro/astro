{
  "name": "@astrojs/org-mode",
  "description": "Add support for Org Mode pages in your Astro site",
  "version": "0.1.0-beta.1",
  "type": "module",
  "types": "./dist/index.d.ts",
  "author": "withastro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/withastro/astro.git",
    "directory": "packages/integrations/org-mode"
  },
  "keywords": [
    "astro-integration",
    "astro-component",
    "org-mode"
  ],
  "bugs": "https://github.com/withastro/astro/issues",
  "exports": {
    ".": "./dist/index.js",
    "./server.js": "./dist/server.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "astro-scripts build \"src/**/*.ts\" && tsc",
    "build:ci": "astro-scripts build \"src/**/*.ts\"",
    "dev": "astro-scripts dev \"src/**/*.ts\"",
    "test": "astro-scripts test --timeout 70000 \"test/**/*.test.js\""
  },
  "dependencies": {
    "@orgajs/metadata": "^2.4.0",
    "@orgajs/rollup": "^1.3.3",
    "estree-util-visit": "^2.0.0"
  },
  "peerDependencies": {
    "astro": "^6.0.0-alpha.0"
  },
  "devDependencies": {
    "@types/estree-jsx": "^1.0.5",
    "astro": "workspace:*",
    "astro-scripts": "workspace:*",
    "linkedom": "^0.18.12"
  },
  "engines": {
    "node": "^20.19.1 || >=22.12.0"
  },
  "publishConfig": {
    "provenance": true
  }
}

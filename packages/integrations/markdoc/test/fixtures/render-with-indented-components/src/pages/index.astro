---
import { getEntry, render } from "astro:content";

const post = await getEntry('blog', 'with-indented-components');
const { Content } = await render(post);
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Content</title>
</head>
<body>
	<Content />	
</body>
</html>

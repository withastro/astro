---
import Layout from '../layouts/Layout.astro';
---
<Layout>
	<main style="padding: 2rem;">
		<h1 class="hero-title">Astro 6 HMR Test</h1>
		<p>Open the browser console and check whether a "Full Reload" occurs when you change the CSS.</p>
		<input type="text" placeholder="Type something here to check if a reload happened (input will be cleared on reload)" style="width: 100%; padding: 0.5rem; margin-top: 1rem;" />
	</main>
</Layout>
---
const linkAttributes = { class: "big", href: "#", rel: "noopener" };
const plainSpread = { a: 0, b: 1, c: 2 };
---

<html>
  <head>
    <style is:global>
			.big { font-size: 3rem; font-weight: 700; }
		</style>
  </head>
  <body>
    <a id="spread-class-global" {...linkAttributes}>Astro</a>
    <div id="spread-plain-global" {...plainSpread} />
  </body>
</html>

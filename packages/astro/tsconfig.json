{
  "extends": "../../tsconfig.base.json",
  "include": ["src", "dev-only.d.ts", "package.json"],
  "exclude": ["dist"],
  "compilerOptions": {
    "composite": true,
    "rootDir": "./src",
    "allowJs": true,
    "declarationDir": "./dist",
    "outDir": "./dist",
    "jsx": "preserve",
    "tsBuildInfoFile": "${configDir}/dist/._cache/tsconfig/tsbuildinfo.json",
    "erasableSyntaxOnly": true
  }
}

{
  "extends": "../../tsconfig.test.json",
  "compilerOptions": {
    "types": ["vite/client", "node"]
  },
  "include": [
    "${configDir}/test/units/**/*.ts",
    "${configDir}/test/*.ts",
    "${configDir}/e2e/*.ts",
    "${configDir}/test/test-adapter.js",
    "${configDir}/test/test-utils.js",
    "${configDir}/package.json"
  ],
  "exclude": [
    "${configDir}/test/units/_temp-fixtures/**",
    "${configDir}/test/fixtures/**",
    "${configDir}/e2e/fixtures/**"
  ],
  "files": [
    "${configDir}/test/fixtures/multiple-jsx-renderers/renderers/woof/index.mjs",
    "${configDir}/test/fixtures/multiple-jsx-renderers/renderers/meow/index.mjs",
    "${configDir}/test/fixtures/before-hydration/deps.mjs"
  ],
  "references": [{ "path": "./tsconfig.build.json" }, { "path": "../../scripts/tsconfig.json" }]
}
